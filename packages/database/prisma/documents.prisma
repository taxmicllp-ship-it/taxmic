// =============================================================================
// DOMAIN: DOCUMENTS — folders, documents, document_versions, document_permissions
// =============================================================================

model folders {
  id          String    @id @default(uuid()) @db.Uuid
  firm_id     String    @db.Uuid
  client_id   String?   @db.Uuid
  parent_id   String?   @db.Uuid
  name        String    @db.VarChar(255)
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  // Relations
  firm      firms       @relation(fields: [firm_id], references: [id], onDelete: Cascade)
  client    clients?    @relation(fields: [client_id], references: [id])
  parent    folders?    @relation("folder_children", fields: [parent_id], references: [id])
  children  folders[]   @relation("folder_children")
  documents documents[]

  @@index([firm_id])
  @@index([client_id])
  @@index([parent_id])
  @@index([deleted_at])
}

model documents {
  id              String                   @id @default(uuid()) @db.Uuid
  firm_id         String                   @db.Uuid
  client_id       String?                  @db.Uuid
  folder_id       String?                  @db.Uuid
  filename        String                   @db.VarChar(500)
  file_key        String                   @db.VarChar(500)
  mime_type       String?                  @db.VarChar(100)
  size_bytes      BigInt
  description     String?
  uploaded_by     String?                  @db.Uuid
  current_version Int                      @default(1)
  search_vector   Unsupported("tsvector")?
  created_at      DateTime                 @default(now())
  updated_at      DateTime                 @updatedAt
  deleted_at      DateTime?

  // Relations
  firm                 firms                  @relation(fields: [firm_id], references: [id], onDelete: Cascade)
  client               clients?               @relation(fields: [client_id], references: [id])
  folder               folders?               @relation(fields: [folder_id], references: [id])
  uploader             users?                 @relation("uploader", fields: [uploaded_by], references: [id])
  document_versions    document_versions[]
  document_permissions document_permissions[]

  @@index([firm_id])
  @@index([client_id])
  @@index([folder_id])
  @@index([uploaded_by])
  @@index([created_at])
  @@index([deleted_at])
  @@index([firm_id, client_id])
}

model document_versions {
  id             String   @id @default(uuid()) @db.Uuid
  document_id    String   @db.Uuid
  version_number Int
  file_key       String   @db.VarChar(500)
  size_bytes     BigInt
  uploaded_by    String?  @db.Uuid
  uploaded_at    DateTime @default(now())
  is_current     Boolean  @default(false)

  // Relations
  document documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  uploader users?    @relation("document_version_uploader", fields: [uploaded_by], references: [id])

  @@unique([document_id, version_number])
  @@index([document_id])
  @@index([uploaded_by])
  @@index([is_current])
}

model document_permissions {
  id          String                   @id @default(uuid()) @db.Uuid
  document_id String                   @db.Uuid
  visibility  document_visibility_enum @default(internal)
  created_at  DateTime                 @default(now())
  updated_at  DateTime                 @updatedAt

  // Relations
  document documents @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id])
  @@index([visibility])
}
